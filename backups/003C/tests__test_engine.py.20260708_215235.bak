import json
import unittest
from pathlib import Path
import tempfile

from petri_lab.presets import PRESETS
from petri_lab.simulation import run_experiment
from petri_lab.validation import validate_result
from petri_lab.artifacts import write_artifact_bundle


class PetriEngineTests(unittest.TestCase):
    def test_microbe_preset_runs_and_validates(self):
        exp = PRESETS["microbial_competition"]()
        exp.grid_size = 32
        exp.steps = 12
        result = run_experiment(exp)
        receipt = validate_result(result)
        self.assertEqual(receipt["status"], "pass")
        self.assertGreater(result["metrics"]["final_total_population"], 0)
        self.assertTrue(result["density"]["normalized"])

    def test_artifact_bundle_written(self):
        exp = PRESETS["cellular_tissue"]()
        exp.grid_size = 28
        exp.steps = 8
        result = run_experiment(exp)
        with tempfile.TemporaryDirectory() as tmp:
            bundle = write_artifact_bundle(Path(tmp), result)
            self.assertTrue(Path(bundle["latest_run"]).exists())
            self.assertTrue(Path(bundle["latest_density"]).exists())
            data = json.loads(Path(bundle["latest_run"]).read_text(encoding="utf-8"))
            self.assertEqual(data["run_id"], result["run_id"])


if __name__ == "__main__":
    unittest.main()
