param([switch]$NoElectronInstall)
$ErrorActionPreference = "Stop"
$Repo = Split-Path -Parent $MyInvocation.MyCommand.Path
Set-Location -LiteralPath $Repo

function Write-GateLine { param([string]$Text,[string]$Color="Cyan") Write-Host $Text -ForegroundColor $Color }

function Show-GateHeader {
    Clear-Host
    Write-GateLine '' 'Cyan'
    Write-GateLine '        [ "LIFE DOES NOT OBEY CHAOS. IT NEGOTIATES THRESHOLDS." ]' 'Blue'
    Write-GateLine '        [ "CLAIMS ARE EARNED. RUNS LEAVE RECEIPTS."              ]' 'Blue'
    Write-GateLine '' 'Cyan'
    Write-GateLine '                 .:-==+####################+==-:.' 'Cyan'
    Write-GateLine '             .:=+######*=-:.          .:-=*######+=:.' 'Cyan'
    Write-GateLine '           .=+####*=:.        .----.        .:=*####+=.' 'Cyan'
    Write-GateLine '         .+####+-.          .-+====+-.          .-+####+.' 'Cyan'
    Write-GateLine '        :####=.        .:-=+*########*+=-:.        .=####:' 'Cyan'
    Write-GateLine '       -###*:       .-+####*+=--::--=+*####+-.       :*###-' 'Blue'
    Write-GateLine '      .###*       .=###*-.     (  )     .-*###=.       *###.' 'Blue'
    Write-GateLine '      :###=      :###=.       ORGANISM      .=###:      =###:' 'Cyan'
    Write-GateLine '      .###*       .=###*-.    SIGNAL     .-*###=.       *###.' 'Blue'
    Write-GateLine '       -###*:       .-+####*+=--::--=+*####+-.       :*###-' 'Blue'
    Write-GateLine '        :####=.        .:-=+*########*+=-:.        .=####:' 'Cyan'
    Write-GateLine '           .=+####*=:.        .----.        .:=*####+=.' 'Cyan'
    Write-GateLine '             .:=+######*=-:.          .:-=*######+=:.' 'Cyan'
    Write-GateLine '                 .:-==+####################+==-:.' 'Cyan'
    Write-GateLine '' 'Cyan'
    Write-GateLine '             [ ORGANISM GATE ]      [ CULTURE LOCK ]      [ RECEIPT READY ]' 'Blue'
    Write-GateLine '' 'Cyan'
    Write-GateLine 'Rule: models simulate; humans validate; receipts govern claims.' 'Blue'
    Write-GateLine 'Flow: preset -> fields -> simulation -> validation -> artifact.' 'Cyan'
    Write-GateLine '' 'Cyan'
}

function Invoke-PetriPython { param([string]$Preset="microbial_competition",[int]$Steps=90,[int]$Grid=56)
    Write-GateLine "Running preset: $Preset  steps=$Steps  grid=$Grid" 'Yellow'
    & python -m petri_lab.cli --root . --preset $Preset --steps $Steps --grid $Grid --json
    if ($LASTEXITCODE -ne 0) { throw "Python simulation failed with exit code $LASTEXITCODE" }
}

function Start-PetriElectron {
    $ElectronRoot = Join-Path $Repo "electron"
    if (-not (Test-Path -LiteralPath $ElectronRoot -PathType Container)) { throw "electron folder missing" }
    Push-Location -LiteralPath $ElectronRoot
    try {
        if (-not $NoElectronInstall.IsPresent) {
            if (-not (Test-Path -LiteralPath (Join-Path $ElectronRoot "node_modules") -PathType Container)) {
                Write-GateLine 'Installing Electron dependencies. This can take a minute.' 'Yellow'
                & npm install
                if ($LASTEXITCODE -ne 0) { throw "npm install failed with exit code $LASTEXITCODE" }
            }
        }
        Write-GateLine 'Opening Electron Microscope HUD.' 'Green'
        & npm start
        if ($LASTEXITCODE -ne 0) { throw "npm start failed with exit code $LASTEXITCODE" }
    } finally { Pop-Location; Set-Location -LiteralPath $Repo }
}

function Show-LatestReceipt {
    $Receipt = Join-Path $Repo "reports\bio\petri_run_latest.json"
    if (-not (Test-Path -LiteralPath $Receipt -PathType Leaf)) { Write-GateLine 'No latest receipt found. Run a preset first.' 'Yellow'; return }
    Get-Content -LiteralPath $Receipt -Raw
}

function Open-ArtifactFolder {
    $Folder = Join-Path $Repo "artifacts\bio\runs"
    if (-not (Test-Path -LiteralPath $Folder -PathType Container)) { New-Item -ItemType Directory -Force -Path $Folder | Out-Null }
    Invoke-Item -LiteralPath $Folder
}

function Show-Roadmap {
    $Roadmap = Join-Path $Repo "ROADMAP.md"
    if (Test-Path -LiteralPath $Roadmap -PathType Leaf) { Get-Content -LiteralPath $Roadmap -Raw }
    if (-not (Test-Path -LiteralPath $Roadmap -PathType Leaf)) { Write-GateLine 'ROADMAP.md missing.' 'Yellow' }
}

while ($true) {
    Show-GateHeader
    Write-GateLine '[1]  Open Electron Microscope HUD                 -> visual organism cockpit' 'Cyan'
    Write-GateLine '[2]  Run Microbial Competition                    -> ecoli / yeast / bacillus / predator' 'Cyan'
    Write-GateLine '[3]  Run Antibiotic Selection                     -> resistant clone pressure test' 'Cyan'
    Write-GateLine '[4]  Run Cellular Tissue Interaction             -> epithelial / immune / cancer-like' 'Cyan'
    Write-GateLine '[5]  Run Biofilm / Dormancy Prototype            -> matrix and spore survival' 'Cyan'
    Write-GateLine '[6]  Validation Tests                             -> compile + unittest' 'Cyan'
    Write-GateLine '[7]  Latest Run Receipt                           -> JSON evidence packet' 'Cyan'
    Write-GateLine '[8]  Open Artifact Folder                         -> run outputs' 'Cyan'
    Write-GateLine '[9]  Roadmap                                      -> evolution path' 'Cyan'
    Write-GateLine '[Q]  Quit' 'Blue'
    Write-GateLine '' 'Cyan'
    $Choice = Read-Host 'Choose'
    if ($Choice -eq '1') { Start-PetriElectron; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '2') { Invoke-PetriPython -Preset 'microbial_competition' -Steps 100 -Grid 64; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '3') { Invoke-PetriPython -Preset 'antibiotic_selection' -Steps 110 -Grid 64; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '4') { Invoke-PetriPython -Preset 'cellular_tissue' -Steps 100 -Grid 64; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '5') { Invoke-PetriPython -Preset 'biofilm_dormancy' -Steps 120 -Grid 64; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '6') { & python -m compileall petri_lab tests; & python -m unittest discover -s tests; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '7') { Show-LatestReceipt; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '8') { Open-ArtifactFolder; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq '9') { Show-Roadmap; Read-Host 'Press Enter to return' | Out-Null }
    if ($Choice -eq 'Q') { break }
    if ($Choice -eq 'q') { break }
}
Set-Location -LiteralPath $Repo
Write-GateLine 'ORGANISM GATE closed. Returned to repo root.' 'Green'
